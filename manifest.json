{
  "manifest_version": 3,
  "name": "TIFON DOWNLOADER",
  "version": "2.1",
  "description": "Baixe automaticamente o conteúdo do seu curso comprado",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage", "downloads", "activeTab", "tabs", "notifications"],
  "host_permissions": [
    "https://tiagofontes.com.br/*",
    "https://www.estrategiaconcursos.com.br/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.estrategiaconcursos.com.br/*"],
      "js": ["content.js"]
    }
  ]
}